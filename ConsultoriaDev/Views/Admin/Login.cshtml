@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center align-items-center py-4 py-md-5">
    <div class="col-12 col-sm-10 col-md-5 col-lg-4">
        <div class="card shadow border-0 cd-hero">
            <div class="card-body p-4 p-md-5">
                <div class="text-center mb-4">
                    <h1 class="h3 fw-bold">Login</h1>
                    <p class="text-secondary small mb-0">Área administrativa — Tech Lead</p>
                </div>

                @if (ViewBag.Erro != null)
                {
                    <div class="alert alert-danger py-2 small" role="alert">@ViewBag.Erro</div>
                }

                <form asp-controller="Admin" asp-action="Login" method="post">
                    <div class="mb-3">
                        <label class="form-label" for="usuario">Usuário</label>
                        <input id="usuario" type="text" name="usuario" class="form-control" required autocomplete="username" />
                    </div>
                    <div class="mb-4">
                        <label class="form-label" for="senha">Senha</label>
                        <input id="senha" type="password" name="senha" class="form-control" required autocomplete="current-password" />
                    </div>
                    <button type="submit" class="btn btn-primary w-100 py-2">Entrar</button>
                </form>
            </div>
        </div>
    </div>
</div>