@{
    ViewData["Title"] = "Início";
}

<section class="cd-hero px-4 py-5 mb-5 text-center text-md-start">
    <div class="row align-items-center">
        <div class="col-md-7">
            <p class="text-uppercase small text-secondary fw-semibold mb-2">Soluções sob medida</p>
            <h1 class="display-5 fw-bold mb-3">Consultoria que acelera o seu time de tecnologia</h1>
            <p class="lead text-secondary mb-4">
                Apoio em arquitetura, código e processos para entregar software com mais qualidade e previsibilidade.
            </p>
            <a class="btn btn-primary btn-lg px-4" asp-controller="Admin" asp-action="Login">Área do Tech Lead</a>
        </div>
        <div class="col-md-5 mt-4 mt-md-0 text-center">
            <div class="cd-feature-icon cd-hero-icon-lg mx-auto" aria-hidden="true">&lt;/&gt;</div>
        </div>
    </div>
</section>

<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="cd-feature-card p-4">
            <div class="cd-feature-icon mb-3">1</div>
            <h2 class="h5 fw-bold">Diagnóstico</h2>
            <p class="text-secondary mb-0 small">Entendemos o contexto, riscos e prioridades do seu produto ou time.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="cd-feature-card p-4">
            <div class="cd-feature-icon mb-3">2</div>
            <h2 class="h5 fw-bold">Plano de ação</h2>
            <p class="text-secondary mb-0 small">Recomendações práticas e alinhadas ao prazo que você precisa cumprir.</p>
        </div>
    </div>
    <div class="col-md-4">
        <div class="cd-feature-card p-4">
            <div class="cd-feature-icon mb-3">3</div>
            <h2 class="h5 fw-bold">Acompanhamento</h2>
            <p class="text-secondary mb-0 small">Suporte à execução para manter o ritmo e reduzir retrabalho.</p>
        </div>
    </div>
</div>
